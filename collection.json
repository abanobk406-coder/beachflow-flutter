":"209f5bb1-6b01-499d-902c-59d1b7d1b951","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"POST","header":[],"body":{"mode":"raw","raw":"{\r\n    \"email\":\"dsfs67@gmail.com\",\r\n    \"otp\":\"133213\"\r\n}","options":{"raw":{"language":"json"}}},"url":"{{Base-Url}}/api/auth/verify-reset-code","urlObject":{"path":["api","auth","verify-reset-code"],"host":["{{Base-Url}}"],"query":[],"variable":[]}},"response":[],"_postman_id":"209f5bb1-6b01-499d-902c-59d1b7d1b951"},{"name":"Reset Password","id":"95e88a80-55ea-4132-98db-59a4222b9c24","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"POST","header":[],"body":{"mode":"raw","raw":"{\r\n    \"email\":\"dsfs67@gmail.com\",\r\n    \"newPassword\": \"yourNewPassword\"\r\n}","options":{"raw":{"language":"json"}}},"url":"{{Base-Url}}/api/auth/reset-password","urlObject":{"path":["api","auth","reset-password"],"host":["{{Base-Url}}"],"query":[],"variable":[]}},"response":[],"_postman_id":"95e88a80-55ea-4132-98db-59a4222b9c24"},{"name":"Resent otp","id":"afa27468-0b7d-43c1-9834-d0d0e4c0444d","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"POST","header":[],"body":{"mode":"raw","raw":"{\r\n    \"email\":\"dsfs67@gmail.com\"\r\n}","options":{"raw":{"language":"json"}}},"url":"{{Base-Url}}/api/auth/resend-otp","urlObject":{"path":["api","auth","resend-otp"],"host":["{{Base-Url}}"],"query":[],"variable":[]}},"response":[],"_postman_id":"afa27468-0b7d-43c1-9834-d0d0e4c0444d"}],"id":"5a003861-0634-4852-8363-a5025d34c659","description":"<p><img src=\"https://img.icons8.com/clouds/256/lock.png\" alt=\"Auth API\" /></p>\n<h1 id=\"auth-api\">Auth API</h1>\n<p>This folder contains all authentication-related API endpoints for the e-commerce application. It covers the complete auth lifecycle including:</p>\n<ul>\n<li><strong>Register</strong> – Create a new user account</li>\n<li><strong>Login</strong> – Authenticate and obtain access credentials</li>\n<li><strong>Verify OTP</strong> – Confirm the user's identity via one-time password</li>\n<li><strong>Resend OTP</strong> – Request a new OTP if the previous one expired or was not received</li>\n<li><strong>Forgot Password</strong> – Initiate the password recovery flow</li>\n<li><strong>Verify Reset Code</strong> – Validate the password reset code sent to the user</li>\n<li><strong>Reset Password</strong> – Set a new password after successful verification</li>\n</ul>\n<p>All requests use the <code>POST</code> method and are routed through the <code>{{Base-Url}}/api/auth/</code> base path.</p>\n","_postman_id":"5a003861-0634-4852-8363-a5025d34c659"},{"name":"User-Api","item":[{"name":"Get All Beaches","id":"7a9499f4-4f68-4f62-9837-43b136679671","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"GET","header":[],"body":{"mode":"raw","raw":"{\r\n    \"email\":\"dsfs67@gmail.com\"\r\n}"},"url":"{{Base-Url}}/api/beach","urlObject":{"path":["api","beach"],"host":["{{Base-Url}}"],"query":[],"variable":[]}},"response":[],"_postman_id":"7a9499f4-4f68-4f62-9837-43b136679671"},{"name":"Search Beaches","id":"bc646fa0-29d7-4b69-99b9-0078a5866a2e","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"GET","header":[],"body":{"mode":"raw","raw":""},"url":"{{Base-Url}}/api/beach/search?q=فينيسيا","urlObject":{"path":["api","beach","search"],"host":["{{Base-Url}}"],"query":[{"key":"q","value":"فينيسيا"}],"variable":[]}},"response":[],"_postman_id":"bc646fa0-29d7-4b69-99b9-0078a5866a2e"},{"name":"Get One Beach","id":"a8dd3384-2b7e-4aa4-8aa4-9244849398a9","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"GET","header":[],"body":{"mode":"raw","raw":""},"url":"{{Base-Url}}/api/beach/3","urlObject":{"path":["api","beach","3"],"host":["{{Base-Url}}"],"query":[],"variable":[]}},"response":[],"_postman_id":"a8dd3384-2b7e-4aa4-8aa4-9244849398a9"},{"name":"Top Rated","id":"79472b80-3191-4c23-bbd2-3dfe5fc93c6d","protocolProfileBehavio